{
  "rewrites": [
    {
      "source": "/run-workflow/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/logs/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}