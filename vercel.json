{
  "rewrites": [
    {
      "source": "/run-workflow",
      "destination": "/run-workflow"
    },
    {
      "source": "/logs",
      "destination": "/logs"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}